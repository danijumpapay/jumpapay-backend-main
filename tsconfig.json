{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    // "moduleResolution": "node",
    "baseUrl": "./",
    "target": "es6",
    // "module": "commonjs",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@root/*": [
        "*"
      ],
      "@src/*": [
        "src/*"
      ],
      "@routes/*": [
        "src/routes/*"
      ],
      "@middlewares/*": [
        "src/middlewares/*"
      ],
      "@controllers/*": [
        "src/controllers/*"
      ],
      "@models/*": [
        "src/models/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@config/*": [
        "src/config/*"
      ],
      "@plugins/*": [
        "src/plugins/*"
      ],
      "@dataTypes/*": [
        "src/dataTypes/*"
      ],
      "@services/*": [
        "src/services/*"
      ],
      "@cache/*": [
        "src/cache/*"
      ],
    },
    "types": [
      "node", "multer"
    ],
    "typeRoots": [
      "./src/types",
      "./node_modules/@types"
    ],
  },
  "types": [
    "node",
    "objection"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}